# =============================================================================
# Vibecoding Workflow - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
vendor/
.pnpm-store/
__pycache__/
*.pyc
.venv/
venv/
env/

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.output/
*.egg-info/

# -----------------------------------------------------------------------------
# IDE and editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.log

# -----------------------------------------------------------------------------
# Environment and secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
*.pem
*.key
secrets.json
credentials.json

# Personal workflow preferences (copy from CLAUDE.local.md.example)
CLAUDE.local.md

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
.pytest_cache/
htmlcov/

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak

# -----------------------------------------------------------------------------
# Package manager locks (uncomment ONE based on your package manager)
# -----------------------------------------------------------------------------
# Keep package-lock.json if using npm
# package-lock.json

# Keep yarn.lock if using yarn
# yarn.lock

# Keep pnpm-lock.yaml if using pnpm
# pnpm-lock.yaml

# -----------------------------------------------------------------------------
# Workflow state (managed by Claude)
# -----------------------------------------------------------------------------
.vibe/*
!.vibe/.gitkeep

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.local
.turbo/
.vercel/
.netlify/
